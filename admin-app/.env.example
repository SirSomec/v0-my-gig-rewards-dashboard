# URL бэкенда (NestJS rewards API)
NEXT_PUBLIC_REWARDS_API_URL=http://localhost:3001

# Секрет для заголовка X-Admin-Key (должен совпадать с ADMIN_SECRET на бэкенде)
NEXT_PUBLIC_ADMIN_SECRET=

# Пароль входа в админ-панель (если не задан — вход без пароля, удобно для разработки)
ADMIN_PANEL_PASSWORD=

# URL основного дашборда (для ссылки «Дашборд» и «Открыть кабинет от имени»)
# NEXT_PUBLIC_DASHBOARD_URL=http://localhost:3000
