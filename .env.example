# Шаблон для единственного .env в корне проекта (рядом с docker-compose.yml).
# Скопируйте в .env и задайте значения. Используется и при локальном запуске, и в Docker.

# URL бэкенда наград (NestJS Rewards API). По умолчанию — localhost:3001
NEXT_PUBLIC_REWARDS_API_URL=http://localhost:3001

# URL API MyGig для авторизации и профиля (POST /auth/phone, POST /auth/code, GET /user/profile). Если задан — вход по номеру телефона и коду из СМС (или DEV_MODE на тестовых окружениях).
# Пример: https://main.test09.mygig.ru
# NEXT_PUBLIC_MYGIG_API_URL=

# ID тестового пользователя для dev-режима. При загрузке дашборда выполняется dev-login (JWT), токен хранится и передаётся в запросах. При загрузке дашборда выполняется dev-login (JWT), токен хранится и передаётся в запросах.
NEXT_PUBLIC_DEV_USER_ID=1

# Ключ для доступа к админ-API (X-Admin-Key). На бэкенде — ADMIN_SECRET, на фронте — NEXT_PUBLIC_ADMIN_SECRET (или задайте только ADMIN_SECRET — подставится при сборке).
# В production задайте свой секрет; по умолчанию в compose используется admin-dev-secret.
# NEXT_PUBLIC_ADMIN_SECRET=
# ADMIN_SECRET=

# Пароль для входа в админ-панель (отдельное приложение на порту 3002). Задайте в .env — доступ только по паролю; если не задан — вход без пароля (удобно для разработки).
# ADMIN_PANEL_PASSWORD=

# URL основного дашборда. Используется в админ-панели для ссылки «Дашборд» и «Открыть кабинет от имени». По умолчанию в compose — http://localhost:3000.
# NEXT_PUBLIC_DASHBOARD_URL=http://localhost:3000

# --- Опционально: переопределение учётных данных БД (по умолчанию в docker-compose: rewards/rewards) ---
# POSTGRES_USER=rewards
# POSTGRES_PASSWORD=rewards
# POSTGRES_DB=rewards
# DATABASE_URL=postgres://rewards:rewards@db:5432/rewards

# --- ETL (MVP): подключение к источнику данных для раздела «Данные ETL» в админке ---
# ETL_HOST=
# ETL_PORT=5432
# ETL_USER=
# ETL_PASSWORD=
# ETL_DATABASE=
# В Docker ETL_SSL_ROOT_CERT не задавайте — сертификат Yandex Cloud уже в образе

# --- Мок TOJ (смены для разработки). Контейнер mock-toj (docker-compose up mock-toj) ---
# В Docker используйте имя сервиса (mock-toj), не localhost — иначе API не достучится до мока (ECONNREFUSED).
# Логин/пароль Basic Auth для эндпоинтов TOJ (job.find-many и т.д.)
# MOCK_TOJ_USER=mock
# MOCK_TOJ_PASSWORD=mock
# Ключ для эндпоинта генерации (X-Admin-Key). Должен совпадать с MOCK_TOJ_ADMIN_KEY в контейнере api.
# MOCK_TOJ_URL=http://mock-toj:3010
# MOCK_TOJ_ADMIN_KEY=mock-admin-key

# --- TOJ: источник смен (синхронизация). В Docker — тот же мок (имя сервиса mock-toj). ---
# TOJ_BASE_URL=http://mock-toj:3010
# TOJ_USER=mock
# TOJ_PASSWORD=mock
# TOJ_SYNC_ENABLED=true
# TOJ_SYNC_MAX_JOBS_PER_RUN=1000
# TOJ_SYNC_INITIAL_DAYS_AGO=7
# TOJ_SYNC_WORKER_BATCH_SIZE=200
# TOJ_SYNC_PAGE_SIZE=500
